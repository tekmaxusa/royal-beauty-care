# Copy to `.cpanel-deploy.env` (gitignored) and set host, user, and SSH key path.

export CPANEL_SSH_HOST=tekmaxhosting.com
export CPANEL_SSH_USER=your_cpanel_user
export CPANEL_SSH_IDENTITY_FILE="$PWD/cpanel_deploy_key"

# Royal SPA + API: dist/ -> royalbeautycare, api/ -> royalbeautycare/_api (see repo .env.production VITE_*).
export FRONTEND_REMOTE_PATH=public_html/bookings/royalbeautycare
export API_REMOTE_PATH=public_html/bookings/royalbeautycare/_api
