# =============================================================================
# PHP API (cPanel) — api/
# Also used for Docker local dev (same keys; DB_* differ from cPanel).
# Copy to `.env` on the server. Never commit real secrets.
# Database = cPanel MySQL (see docs/DEPLOYMENT.md). Frontend VITE_* = repo root `.env`.
#
# Same-origin deploy (SPA + API on cPanel): docs/CPANEL-FULL-DEPLOY.md
# Production UI: https://yourdomain.com/bookings/ — example server values:
#   ALLOWED_ORIGINS=https://tekmaxhosting.com
#   CHB_SESSION_CROSS_SITE=0
#   CHB_APP_PUBLIC_URL=https://yourdomain.com/bookings
# Access tokens are HMAC-signed (see config/token_auth.php); set CHB_TOKEN_SECRET in production.
# =============================================================================

# CORS: comma-separated browser origins. Production: add your GitHub Pages origin, e.g.
# https://youruser.github.io,https://youruser.github.io/your-site
# Production (same-origin): https://tekmaxhosting.com — add www if you serve both.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Set to 1 on HTTPS API when the SPA is on another site (e.g. GitHub Pages) so session cookies work with credentialed fetch.
# Set to 0 when SPA and API are the same site (typical cPanel full stack).
CHB_SESSION_CROSS_SITE=0
# Token auth signing secret (recommended in production). Long random string.
# If empty, backend falls back to derived secrets for compatibility.
CHB_TOKEN_SECRET=
# Vite/React container (when using docker compose with `frontend` service)
FRONTEND_PORT=3000

WEB_PORT=8080
# Merchant admin is served by the same `web` container: http://localhost:WEB_PORT/admin/login
# Docker phpMyAdmin → http://localhost:PMA_PORT (same DB as `db`; login: DB_USER / DB_PASS or root / DB_ROOT_PASSWORD)
PMA_PORT=8081
# Host port mapped from Docker MySQL (compose maps 3307→3306). Host clients should use DB_HOST=127.0.0.1 + DB_PORT=3307.
DB_PORT=3307
DB_NAME=royal_beauty_care
DB_USER=salon_user
DB_PASS=salon_secret
DB_ROOT_PASSWORD=root_secret_change_me

# First merchant admin (only when no user has role=admin yet). Creates or promotes user + sets password.
# Sign-in always uses email + password (display name is ADMIN_NAME).
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=

# Optional — POST JSON to this URL on each new booking (Slack/Discord incoming webhook, Zapier, etc.)
# Payload: event, booking_id, status, booking_date, booking_time, service_*, client_*, user_id, is_guest, created_at
# ADMIN_BOOKING_WEBHOOK_SECRET — if set, sent as Authorization: Bearer <secret>
# After changing these, restart the PHP container (e.g. docker compose restart web) — PHP loads .env once per process.
ADMIN_BOOKING_WEBHOOK_URL=
ADMIN_BOOKING_WEBHOOK_SECRET=

# Optional — Google OAuth (“Continue with Google”)
# PHP reads this file automatically (see config/env.php) when vars are empty in the shell/Docker layer.
# Create an OAuth “Web application” client: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match EXACTLY what Google receives, e.g.:
#   http://localhost:8080/google-oauth-callback.php
#   https://yourdomain.com/google-oauth-callback.php
# If you use HTTPS in front (Cloudflare, nginx, etc.), either list the https URI in Google Console
# or set GOOGLE_REDIRECT_URI below explicitly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Contact form → PHP mail() (set on your server / Docker so messages are delivered)
# CONTACT_MAIL_TO overrides salon contact_email from config/salon_data.php
CONTACT_MAIL_TO=
# A mailbox your host allows as From (often noreply@yourdomain.com)
CONTACT_MAIL_FROM=
# Gmail SMTP (Option B). Recommended: use a Gmail App Password (requires 2FA).
# For Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=tls
#   SMTP_USER=youraccount@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   (App Password)
#   SMTP_FROM_EMAIL=youraccount@gmail.com
#   SMTP_FROM_NAME="Royal Beauty Care"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
# Local/Docker: PHP mail() usually fails without an MTA. For testing only, log reset links instead of sending:
# CHB_DEV_MAIL_LOG=1
# Then: docker compose logs web | grep CHB_DEV_MAIL_LOG

# Google Apps Script integration has been removed from this project.

# Public URL of the React app (no trailing slash). Required for password-reset links in emails, e.g.:
# https://youruser.github.io/your-site  or  https://bookings.yoursalon.com
# Also used so Google OAuth returns users to /login and /dashboard on the SPA (not :8080, where those paths 404).
# Docker Compose sets CHB_APP_PUBLIC_URL=http://localhost:3000 on the web service unless you override it.
CHB_APP_PUBLIC_URL=

# CardPointe / CardConnect (deposit payments) — put credentials here (canonical for PHP + recommended for CLI scripts).
# Bash helpers in scripts/ also read this file via scripts/_cardconnect_env.sh.
# For this merchant, verified host: https://fts.cardconnect.com
CARDCONNECT_BASE_URL=https://fts.cardconnect.com
CARDCONNECT_MERCHID=
CARDCONNECT_API_USER=
CARDCONNECT_API_PASSWORD=
CARDCONNECT_CURRENCY=USD
# Optional extra query string for the Hosted iFrame Tokenizer (booking-meta paymentTokenizer.iframeSrc).
# Example: site=yourSiteId  (no leading ?)
# CARDCONNECT_TOKENIZER_QUERY=

# Optional local development switch.
# 1 = bypass live payment call and mark deposit approved locally.
# booking-meta.php exposes this as paymentBypass so the booking UI hides the card form.
# Monorepo: CHB_PAYMENT_SKIP in the repo-root .env overrides this line (same key).
# You may add an inline comment after the value (e.g. =1  # dev); the parser strips it.
# Never enable in production.
CHB_PAYMENT_SKIP=0

# Admin → /admin/bookings: Cancel tries CardConnect void then refund on the original retref (deposit reversal).
# Declines if neither succeeds; use CardPointe Reporting or fix config, then cancel again.
